# LuxPower cloud login
username=your_luxpower_email_or_username
password=your_luxpower_password
station=Your Plant Name

# Inverter + dongle used by local Modbus + history checks
inverter_sn=YOUR_10_DIGIT_INVERTER_SN
dongle_sn=YOUR_DONGLE_SN
inverter_ip=192.168.10.67

# Optional Solar Assistant fields (only needed for solar_assistant_*.py scripts)
solarassistant_email=you@example.com
cloudProxy=https://your-subdomain.za.solar-assistant.io
